# Normalize line endings: text files use LF in the repo.
* text=auto

# Files that must always be LF on disk (executed inside Linux containers).
*.sh text eol=lf
Dockerfile text eol=lf
docker-compose.yml text eol=lf

# Windows scripts keep CRLF.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf
